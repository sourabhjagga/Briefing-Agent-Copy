# ─── TELEGRAM BOT CONFIGURATION ─────────────────────────────────────────
# Token of the main credit card Telegram bot (obtain from @BotFather)
TELEGRAM_BOT_TOKEN=your_cc_bot_token_here

# Token of the deals Telegram bot (optional, defaults to CC bot if omitted)
DEALS_BOT_TOKEN=your_deals_bot_token_here

# Your personal Telegram Chat ID (where summaries and alerts will be sent)
TELEGRAM_CHAT_ID=your_personal_chat_id_here

# ─── CUSTOM CATEGORIES ─────────────────────────────────────────────────
# Additional briefing categories (e.g., Office, Crypto, Fitness) can be
# created and configured entirely through the Web Dashboard at runtime.
# Each custom category supports its own:
#   - Telegram Bot Token (from @BotFather)
#   - Chat ID (your personal or group chat)
#   - AI Prompt (customized summarization instructions)
# No environment variables needed for custom categories — manage them via the dashboard.

# ─── TELEGRAM PERSONAL API CREDENTIALS ──────────────────────────────────
# Required for scraping private subscribed Telegram channels (get from my.telegram.org)
TELEGRAM_API_ID=your_telegram_api_id_here
TELEGRAM_API_HASH=your_telegram_api_hash_here

# ─── AI MODELS & CREDENTIALS ────────────────────────────────────────────
# Gemini API Key (obtain from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter Key (obtain from openrouter.ai - used for fallback to free models)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ─── SERVER CONFIGURATION ───────────────────────────────────────────────
# Port for the web dashboard and health check (Coolify proxy routes to this)
HEALTH_PORT=3000

# ─── SCHEDULER SETTINGS (IST TIMEZONE) ──────────────────────────────────
# Daily briefing triggers default to 6:00 AM, 2:00 PM, and 10:00 PM IST
SUMMARY_HOUR=22
SUMMARY_MINUTE=00

# ─── WHATSAPP INITIAL SEED TARGETS (OPTIONAL) ───────────────────────────
# Comma-separated list of WhatsApp group/channel IDs (e.g. 120363xxx@g.us,120363yyy@newsletter)
# You can also add these dynamically via the Web Dashboard
WHATSAPP_GROUPS=

# ─── CLOUDFLARE BYPASS CONFIGURATION (FLARESOLVERR) ────────────────────
# Optional: Set this to route scrapers through a FlareSolverr container to bypass Cloudflare
# Default inside docker-compose is http://flaresolverr:8191/v1
FLARESOLVERR_URL=
FLARESOLVERR_LOG_LEVEL=info
